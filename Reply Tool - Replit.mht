@charset "utf-8";

* { box-sizing: border-box; margin: 0px; padding: 0px; }

html, body { height: 100%; }

body { font-family: Inter, -apple-system, BlinkMacSystemFont, sans-serif; background: linear-gradient(135deg, rgb(102, 126, 234) 0%, rgb(118, 75, 162) 100%); color: rgb(31, 41, 55); min-height: 100vh; padding: 20px; line-height: 1.5; }

.container { max-width: 640px; margin: 0px auto; padding: 32px 0px; }

header { text-align: center; margin-bottom: 32px; color: rgb(255, 255, 255); }

header h1 { font-size: 32px; font-weight: 700; margin-bottom: 8px; letter-spacing: -0.5px; }

header p { font-size: 16px; opacity: 0.9; }

.card { background: rgb(255, 255, 255); border-radius: 16px; padding: 24px; box-shadow: rgba(0, 0, 0, 0.15) 0px 20px 50px; margin-bottom: 20px; }

label { display: block; font-weight: 600; font-size: 14px; margin-bottom: 8px; color: rgb(55, 65, 81); }

textarea { width: 100%; min-height: 130px; padding: 14px 16px; font-family: inherit; font-size: 15px; color: rgb(31, 41, 55); background: rgb(249, 250, 251); border: 2px solid rgb(229, 231, 235); border-radius: 12px; resize: vertical; transition: border-color 0.2s, background 0.2s; }

textarea:focus { outline: none; border-color: rgb(102, 126, 234); background: rgb(255, 255, 255); }

.btn { width: 100%; margin-top: 16px; padding: 14px 20px; font-family: inherit; font-size: 16px; font-weight: 600; color: rgb(255, 255, 255); background: linear-gradient(135deg, rgb(102, 126, 234) 0%, rgb(118, 75, 162) 100%); border: none; border-radius: 12px; cursor: pointer; transition: transform 0.15s, box-shadow 0.15s, opacity 0.2s; }

.btn:hover:not(:disabled) { transform: translateY(-1px); box-shadow: rgba(102, 126, 234, 0.35) 0px 8px 20px; }

.btn:active:not(:disabled) { transform: translateY(0px); }

.btn:disabled { opacity: 0.6; cursor: not-allowed; }

.results { display: none; }

.results.visible { display: block; }

.results h2 { color: rgb(255, 255, 255); font-size: 18px; font-weight: 600; margin-bottom: 12px; padding-left: 4px; }

.reply-card { background: rgb(255, 255, 255); border-radius: 12px; padding: 18px; margin-bottom: 12px; box-shadow: rgba(0, 0, 0, 0.1) 0px 8px 24px; border-left: 4px solid transparent; animation: 0.3s ease-out 0s 1 normal none running slideIn; }

.reply-card.normal { border-left-color: rgb(59, 130, 246); }

.reply-card.crush { border-left-color: rgb(236, 72, 153); }

.reply-card.attitude { border-left-color: rgb(239, 68, 68); }

.reply-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 10px; }

.reply-tag { display: inline-flex; align-items: center; gap: 6px; font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; padding: 4px 10px; border-radius: 999px; }

.reply-card.normal .reply-tag { background: rgb(219, 234, 254); color: rgb(30, 64, 175); }

.reply-card.crush .reply-tag { background: rgb(252, 231, 243); color: rgb(157, 23, 77); }

.reply-card.attitude .reply-tag { background: rgb(254, 226, 226); color: rgb(153, 27, 27); }

.copy-btn { background: transparent; border: 1px solid rgb(229, 231, 235); color: rgb(107, 114, 128); font-family: inherit; font-size: 12px; font-weight: 500; padding: 6px 12px; border-radius: 8px; cursor: pointer; transition: 0.15s; }

.copy-btn:hover { background: rgb(243, 244, 246); color: rgb(31, 41, 55); border-color: rgb(209, 213, 219); }

.copy-btn.copied { background: rgb(16, 185, 129); border-color: rgb(16, 185, 129); color: rgb(255, 255, 255); }

.reply-text { color: rgb(55, 65, 81); font-size: 15px; white-space: pre-wrap; overflow-wrap: break-word; }

.empty-hint { color: rgb(156, 163, 175); font-size: 13px; margin-top: 8px; }

footer { text-align: center; color: rgba(255, 255, 255, 0.8); font-size: 13px; margin-top: 24px; }

@keyframes slideIn { 
  0% { opacity: 0; transform: translateY(8px); }
  100% { opacity: 1; transform: translateY(0px); }
}

@media (max-width: 480px) {
  body { padding: 12px; }
  .container { padding: 16px 0px; }
  header h1 { font-size: 26px; }
  .card { padding: 18px; border-radius: 14px; }
  textarea { min-height: 110px; font-size: 14px; }
  .btn { padding: 13px 18px; font-size: 15px; }
  .reply-card { padding: 16px; }
}
